# Claude API (server-side only)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Clerk Auth
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret

# Neon PostgreSQL (server-side only)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Google OAuth
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_API_KEY=your-google-api-key

# GitHub OAuth
VITE_GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Spotify OAuth
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Netlify Functions URL (optional, defaults to /.netlify/functions)
# VITE_NETLIFY_FUNCTIONS_URL=/.netlify/functions

# CORS origin (set to your production domain)
# ALLOWED_ORIGIN=https://your-domain.com
